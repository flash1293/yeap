{
  "name": "yeap",
  "private": true,
  "scripts": {
    "build:bot-image": "docker build -f infra/bot.Dockerfile -t yeap-bot:latest .",
    "dev": "pnpm build:bot-image && docker compose -f infra/docker-compose.yml up --build",
